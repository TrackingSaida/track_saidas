# Backblaze B2 — fotos de entrega (upload presigned)
# Application Key: Read and Write, bucket ts-prod-entregas-fotos, prefixo "saida/".
# Se der 403 "not entitled", crie uma nova key com essas opções (não use só Write Only).
B2_BUCKET_NAME=ts-prod-entregas-fotos
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com

# Limpeza de histórico (D-60)
CRON_CLEANUP_SECRET=
HISTORY_RETENTION_DAYS=60
HISTORY_CLEANUP_BATCH_SIZE=3000
HISTORY_CLEANUP_MAX_RUNTIME_SECONDS=540
HISTORY_CLEANUP_B2_ENABLED=true

# Google Places (New API) — fallback de autocomplete/sugestões (somente backend)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ENABLED=false
GOOGLE_PLACES_AUTO_FALLBACK=true
GOOGLE_AUTO_FALLBACK_MIN_SCORE=60
GOOGLE_PLACES_SESSION_LIMIT=8
ADDRESS_PROVIDER_TIMEOUT_SEC=2

# Google Geocoding — fallback final opcional ao salvar endereço sem coordenadas
GOOGLE_GEOCODING_ENABLED=false
GOOGLE_GEOCODING_API_KEY=

# Sessão mobile motoboy (JWT + refresh token)
MOTOBOY_ACCESS_TOKEN_EXPIRE_DAYS=30
MOTOBOY_REFRESH_TOKEN_EXPIRE_DAYS=90

# Pool SQLAlchemy (bipagem concorrente). Máx por instância ≈ DB_POOL_SIZE + DB_MAX_OVERFLOW.
# Não ultrapasse o limite de conexões do Postgres no Render.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300
